@OptIn(ExperimentalFoundationApi::class)
@Composable
fun NewTabPage(
    isDarkMode: Boolean,
    favorites: List<FavItem>,
    isEditMode: Boolean,
    onEditModeChange: (Boolean) -> Unit,
    onNavigate: (String, Color) -> Unit,
    onReorder: (Int, Int) -> Unit
) {
    val textColor = if (isDarkMode) AppColors.TextPrimaryDark else AppColors.TextPrimaryLight
    val subTextColor = if (isDarkMode) AppColors.TextSecondaryDark else AppColors.TextSecondaryLight
    val logoUrl = if (isDarkMode) LOGO_BLACK_BG else LOGO_WHITE_BG

    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(horizontal = 24.dp),
        horizontalAlignment = Alignment.CenterHorizontally
    ) {
        Spacer(modifier = Modifier.height(60.dp))

        // Brand Section
        Column(horizontalAlignment = Alignment.CenterHorizontally) {
            Row(verticalAlignment = Alignment.CenterVertically, horizontalArrangement = Arrangement.spacedBy(12.dp)) {
                // Logo
                Box(
                    modifier = Modifier
                        .size(50.dp)
                        .clip(RoundedCornerShape(14.dp))
                        .background(if (isDarkMode) Color.Black else Color.White), // Fallback
                    contentAlignment = Alignment.Center
                ) {
                    AsyncImage(
                        model = logoUrl,
                        contentDescription = "Logo",
                        modifier = Modifier.fillMaxSize(),
                        contentScale = ContentScale.Crop
                    )
                }
                // Name
                Text(
                    text = "EVENLY",
                    fontFamily = BebasNeue,
                    fontSize = 42.sp,
                    color = textColor,
                    letterSpacing = 2.sp
                )
            }
            // Slogan with small gap
            Spacer(modifier = Modifier.height(2.dp))
            Text(
                text = "Explore the internet through Evenly",
                fontFamily = Inter,
                fontSize = 14.sp,
                fontWeight = FontWeight.Medium,
                color = textColor.copy(alpha = 0.6f)
            )
        }

        Spacer(modifier = Modifier.height(40.dp))

        // Grid Section
        Column(modifier = Modifier.fillMaxWidth()) {
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(start = 4.dp, end = 4.dp, bottom = 12.dp),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    "FAVORITES",
                    fontFamily = Inter,
                    fontSize = 13.sp,
                    fontWeight = FontWeight.SemiBold,
                    color = subTextColor
                )
                TextButton(onClick = { onEditModeChange(!isEditMode) }) {
                    Text(
                        if (isEditMode) "Done" else "Edit",
                        fontFamily = Inter,
                        fontSize = 13.sp,
                        fontWeight = FontWeight.SemiBold,
                        color = AppColors.Accent
                    )
                }
            }

            // Drag and Drop Grid
            val state = rememberLazyGridState()
            val haptic = LocalHapticFeedback.current
            
            // For simplicity in this snippet, we implement drag logic on touch
            // Real apps might use more complex gesture detectors for smooth auto-scroll
            LazyVerticalGrid(
                columns = GridCells.Fixed(4),
                state = state,
                verticalArrangement = Arrangement.spacedBy(12.dp),
                horizontalArrangement = Arrangement.spacedBy(12.dp),
                modifier = Modifier.height(250.dp) // Fixed height for NTP grid
            ) {
                itemsIndexed(favorites) { index, item ->
                    val animatedModifier = if (isEditMode) {
                        Modifier.padding(2.dp)
                    } else {
                        Modifier.padding(0.dp)
                    }
                    
                    Box(
                        modifier = animatedModifier
                            .clip(RoundedCornerShape(14.dp))
                            .combinedClickable(
                                enabled = true,
                                onClick = {
                                    if (!isEditMode) onNavigate(item.name, item.bgColor)
                                },
                                onLongClick = {
                                    if (!isEditMode) onEditModeChange(true)
                                    haptic.performHapticFeedback(HapticFeedbackType.LongPress)
                                }
                            )
                    ) {
                        if (isEditMode) {
                            WiggleAnimation {
                                FavItemUI(item = item, isDarkMode = isDarkMode, showDeleteBadge = true)
                            }
                        } else {
                            FavItemUI(item = item, isDarkMode = isDarkMode, showDeleteBadge = false)
                        }
                    }
                }
            }
        }
    }
}

