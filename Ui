@Composable
fun EvenlyBrowserApp() {
    var isDarkMode by remember { mutableStateOf(true) }
    
    // State
    var isEditMode by remember { mutableStateOf(false) }
    var favorites by remember { 
        mutableStateOf(listOf(
            FavItem("Google", "G", Color.White, Color(0xFF4285F4)),
            FavItem("YouTube", "Y", Color.White, Color(0xFFFF0000)),
            FavItem("Reddit", "R", Color.White, Color(0xFFFF4500)),
            FavItem("Netflix", "N", Color.White, Color(0xFFE50914)),
            FavItem("Amazon", "A", Color.White, Color(0xFFFF9900)),
            FavItem("Spotify", "S", Color.White, Color(0xFF1DB954)),
            FavItem("Twitter", "X", Color.White, Color.Black),
            FavItem("Wiki", "W", Color.Black, Color(0xFFEEEEEE))
        ))
    }
    
    var tabs by remember {
        mutableStateOf(listOf(
            TabItem(0, "Evenly", "E", Color.Transparent, true, true)
        ))
    }
    var nextTabId by remember { mutableStateOf(1) }

    val backgroundColor = if (isDarkMode) AppColors.DarkBackground else AppColors.LightBackground
    val cardColor = if (isDarkMode) AppColors.DarkCard else AppColors.LightCard
    val textColor = if (isDarkMode) AppColors.TextPrimaryDark else AppColors.TextPrimaryLight
    val subTextColor = if (isDarkMode) AppColors.TextSecondaryDark else AppColors.TextSecondaryLight
    val borderColor = if (isDarkMode) AppColors.DarkBorder else AppColors.LightBorder

    // Modal States
    var showMenuSheet by remember { mutableStateOf(false) }
    var showTabSheet by remember { mutableStateOf(false) }
    var showDetailSheet by remember { mutableStateOf(false) }
    var detailContent by remember { mutableStateOf(Pair("Title", "")) }

    Box(modifier = Modifier
        .fillMaxSize()
        .background(backgroundColor)
    ) {
        Column(modifier = Modifier.fillMaxSize()) {
            // --- HEADER ---
            SearchHeader(cardColor, borderColor, subTextColor, isDarkMode)

            // --- CONTENT (NTP) ---
            NewTabPage(
                isDarkMode = isDarkMode,
                favorites = favorites,
                isEditMode = isEditMode,
                onEditModeChange = { isEditMode = it },
                onNavigate = { name, bg ->
                    // Simulate load logic
                    val activeTab = tabs.indexOfFirst { it.isActive }
                    if (activeTab != -1) {
                        tabs[activeTab].title = name
                        tabs[activeTab].letter = name[0].toString()
                        tabs[activeTab].bg = bg
                        tabs[activeTab].isEvenly = false
                    }
                },
                onReorder = { from, to ->
                    // Reorder logic
                    val list = favorites.toMutableList()
                    val item = list.removeAt(from)
                    if (to >= list.size) list.add(item) else list.add(to, item)
                    favorites = list
                }
            )
        }

        // --- BOTTOM NAV ---
        BottomNavBar(
            isDarkMode = isDarkMode,
            onMenuClick = { showMenuSheet = true },
            onTabsClick = { showTabSheet = true }
        )

        // --- MODALS ---
        if (showMenuSheet) {
            ResizableBottomSheet(
                isDarkMode = isDarkMode,
                onDismiss = { showMenuSheet = false },
                content = {
                    SettingsMenuContent(
                        isDarkMode = isDarkMode,
                        onThemeToggle = { isDarkMode = !isDarkMode },
                        onHistoryClick = {
                            showMenuSheet = false
                            detailContent = Pair("History", "History List Placeholder")
                            showDetailSheet = true
                        },
                        onCookiesClick = {
                            showMenuSheet = false
                            detailContent = Pair("Cookies", "Clear Data Button Placeholder")
                            showDetailSheet = true
                        }
                    )
                }
            )
        }

        if (showTabSheet) {
            ResizableBottomSheet(
                isDarkMode = isDarkMode,
                onDismiss = { showTabSheet = false },
                content = {
                    TabSwitcherContent(
                        tabs = tabs,
                        isDarkMode = isDarkMode,
                        onAddTab = {
                            tabs = tabs.map { it.copy(isActive = false) }.toMutableList().apply {
                                add(TabItem(nextTabId++, "Evenly", "E", Color.Transparent, true, true))
                            }
                            showTabSheet = false
                        },
                        onSelectTab = { id ->
                            tabs = tabs.map { it.copy(isActive = it.id == id) }
                            showTabSheet = false
                        },
                        onCloseTab = { id ->
                            val list = tabs.toMutableList()
                            val idx = list.indexOfFirst { it.id == id }
                            if (list.size > 1 && idx != -1) {
                                val wasActive = list[idx].isActive
                                list.removeAt(idx)
                                if (wasActive) list[maxOf(0, idx - 1)].isActive = true
                                tabs = list
                            }
                        }
                    )
                }
            )
        }

        if (showDetailSheet) {
            ResizableBottomSheet(
                isDarkMode = isDarkMode,
                onDismiss = { showDetailSheet = false },
                content = {
                    DetailContent(title = detailContent.first, content = detailContent.second, isDarkMode = isDarkMode)
                }
            )
        }
    }
}

