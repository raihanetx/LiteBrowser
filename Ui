@Composable
fun TabSwitcherContent(
    tabs: List<TabItem>,
    isDarkMode: Boolean,
    onAddTab: () -> Unit,
    onSelectTab: (Int) -> Unit,
    onCloseTab: (Int) -> Unit
) {
    val cardColor = if (isDarkMode) AppColors.DarkCard else AppColors.LightCard
    val textColor = if (isDarkMode) AppColors.TextPrimaryDark else AppColors.TextPrimaryLight

    Column {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(horizontal = 16.dp),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text("Tabs", fontFamily = Inter, fontSize = 18.sp, fontWeight = FontWeight.Bold, color = textColor)
            TextButton(onClick = { /* Done logic handled by sheet dismiss */ }) {
                Text("Done", color = AppColors.Accent, fontWeight = FontWeight.SemiBold)
            }
        }
        
        // Tab Grid
        LazyVerticalGrid(
            columns = GridCells.Adaptive(minSize = 70.dp),
            contentPadding = PaddingValues(16.dp),
            horizontalArrangement = Arrangement.spacedBy(16.dp),
            verticalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            items(tabs.size) { index ->
                val tab = tabs[index]
                TabCircle(
                    item = tab,
                    isDarkMode = isDarkMode,
                    onClick = { onSelectTab(tab.id) },
                    onClose = { onCloseTab(tab.id) }
                )
            }
            // Add Tab Button
            item {
                Column(horizontalAlignment = Alignment.CenterHorizontally) {
                    Box(
                        modifier = Modifier
                            .size(60.dp)
                            .background(cardColor, CircleShape)
                            .border(2.dp, if (isDarkMode) Color(0xFF2c2c2c) else Color(0xFFE0E0E0), CircleShape)
                            .clickable { onAddTab() },
                        contentAlignment = Alignment.Center
                    ) {
                        Icon(Icons.Rounded.Add, contentDescription = "Add Tab", tint = Color.Gray, modifier = Modifier.size(24.dp))
                    }
                    Spacer(modifier = Modifier.height(6.dp))
                    Text("New Tab", color = Color.Gray, fontSize = 11.sp)
                }
            }
        }
    }
}

@Composable
fun TabCircle(item: TabItem, isDarkMode: Boolean, onClick: () -> Unit, onClose: () -> Unit) {
    val cardColor = if (isDarkMode) AppColors.DarkCard else AppColors.LightCard
    val textColor = if (isDarkMode) AppColors.TextPrimaryDark else AppColors.TextPrimaryLight

    Column(horizontalAlignment = Alignment.CenterHorizontally) {
        Box(
            modifier = Modifier
                .size(60.dp)
                .clip(CircleShape)
                .background(
                    if (item.isEvenly) Brush.linearGradient(listOf(Color(0xFF0a84ff), Color(0xFF00c6ff)))
                    else Brush.verticalGradient(listOf(item.bg, item.bg))
                )
                .border(2.dp, if (item.isActive) AppColors.Accent else Color.Transparent, CircleShape)
                .clickable { onClick() },
            contentAlignment = Alignment.Center
        ) {
            Text(item.letter, color = Color.White, fontSize = 22.sp, fontWeight = FontWeight.Bold)
            if (item.isActive) {
                Box(
                    modifier = Modifier
                        .matchParentSize()
                        .background(Color.Black.copy(alpha = 0.1f))
                )
            }
        }
        Spacer(modifier = Modifier.height(6.dp))
        Text(item.title, color = Color.Gray, fontSize = 11.sp, maxLines = 1, overflow = TextOverflow.Ellipsis, modifier = Modifier.width(60.dp), textAlign = TextAlign.Center)
    }
}

@Composable
fun DetailContent(title: String, content: String, isDarkMode: Boolean) {
    val textColor = if (isDarkMode) AppColors.TextPrimaryDark else AppColors.TextPrimaryLight
    Column(
        modifier = Modifier
            .fillMaxWidth()
            .padding(16.dp)
    ) {
        Text(title, fontSize = 18.sp, fontWeight = FontWeight.Bold, color = textColor)
        Spacer(modifier = Modifier.height(16.dp))
        Text(content, color = Color.Gray)
    }
}

