// Color Palette
val PrimaryBlue = Color(0xFF007AFF)
val SurfaceWhite = Color(0xFFFFFFFF)
val Gray50 = Color(0xFFF9FAFB)
val Gray100 = Color(0xFFF3F4F6)
val Gray200 = Color(0xFFE5E7EB)
val Gray300 = Color(0xFFD1D5DB)
val Gray400 = Color(0xFF9CA3AF)
val Gray500 = Color(0xFF6B7280)
val Gray600 = Color(0xFF4B5563)
val Gray800 = Color(0xFF1F2937)

// Data Models
data class Favorite(val name: String, val initial: String, val color: Color)
data class BrowserTab(val url: String, val initial: String, val color: Color)

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            MaterialTheme {
                Surface(color = SurfaceWhite, modifier = Modifier.fillMaxSize()) {
                    BrowserApp()
                }
            }
        }
    }
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun BrowserApp() {
    val focusManager = LocalFocusManager.current
    val coroutineScope = rememberCoroutineScope()
    
    // States
    var isSearchFocused by remember { mutableStateOf(false) }
    var searchQuery by remember { mutableStateOf("google.com") }
    var loadingProgress by remember { mutableStateOf(0f) }
    
    var showTabsSheet by remember { mutableStateOf(false) }
    var showMenuSheet by remember { mutableStateOf(false) }
    
    var zoomLevel by remember { mutableStateOf(100) }
    var isDarkMode by remember { mutableStateOf(false) }
    var isDesktopMode by remember { mutableStateOf(false) }

    // Dummy Data
    val favorites = remember { mutableStateListOf(
        Favorite("Google", "G", Color(0xFF3B82F6)),
        Favorite("YouTube", "Y", Color(0xFFEF4444)),
        Favorite("Instagram", "I", Color(0xFFEC4899)),
        Favorite("X", "X", Gray800),
        Favorite("Spotify", "S", Color(0xFF10B981)),
        Favorite("Amazon", "A", Color(0xFFF59E0B)),
        Favorite("Github", "G", Gray800)
    )}

    val openTabs = remember { mutableStateListOf(
        BrowserTab("google.com", "G", Color(0xFF3B82F6)),
        BrowserTab("youtube.com", "Y", Color(0xFFEF4444))
    )}

    // Functions
    fun simulateLoading() {
        coroutineScope.launch {
            loadingProgress = 0f
            delay(50)
            loadingProgress = 0.3f
            delay(250)
            loadingProgress = 0.7f
            delay(400)
            loadingProgress = 1f
            delay(300)
            loadingProgress = 0f
        }
    }

    fun clearFocusAndOverlays() {
        focusManager.clearFocus()
        showTabsSheet = false
        showMenuSheet = false
    }

    Box(modifier = Modifier.fillMaxSize()) {
        Column(modifier = Modifier.fillMaxSize()) {
            
            // --- HEADER ---
            Box(modifier = Modifier.background(SurfaceWhite)) {
                Column {
                    Row(
                        modifier = Modifier
                            .fillMaxWidth()
                            .padding(horizontal = 16.dp, vertical = 8.dp),
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        // Search Bar
                        val borderColor by animateColorAsState(if (isSearchFocused) Gray300 else Gray200)
                        
                        Row(
                            modifier = Modifier
                                .weight(1f)
                                .height(38.dp)
                                .background(Gray100, CircleShape)
                                .border(1.dp, borderColor, CircleShape)
                                .padding(horizontal = 16.dp),
                            verticalAlignment = Alignment.CenterVertically
                        ) {
                            Icon(
                                imageVector = Icons.Outlined.Search,
                                contentDescription = "Search",
                                tint = Gray400,
                                modifier = Modifier.size(18.dp)
                            )
                            Spacer(modifier = Modifier.width(8.dp))
                            BasicTextField(
                                value = searchQuery,
                                onValueChange = { searchQuery = it },
                                textStyle = TextStyle(
                                    fontSize = 14.sp,
                                    fontWeight = FontWeight.Medium,
                                    color = Gray800
                                ),
                                singleLine = true,
                                keyboardOptions = KeyboardOptions(imeAction = ImeAction.Go),
                                keyboardActions = KeyboardActions(onGo = {
                                    focusManager.clearFocus()
                                    simulateLoading()
                                }),
                                cursorBrush = SolidColor(PrimaryBlue),
                                modifier = Modifier
                                    .fillMaxWidth()
                                    .onFocusChanged { isSearchFocused = it.isFocused }
                            )
                        }

                        // Header Actions (Animated hiding)
                        AnimatedVisibility(visible = !isSearchFocused) {
                            Row(
                                modifier = Modifier.padding(start = 8.dp),
                                horizontalArrangement = Arrangement.spacedBy(6.dp)
                            ) {
                                // Tab Button
                                Box(
                                    modifier = Modifier
                                        .size(38.dp)
                                        .background(SurfaceWhite, CircleShape)
                                        .border(1.dp, Gray200, CircleShape)
                                        .clickable { showTabsSheet = true },
                                    contentAlignment = Alignment.Center
                                ) {
                                    Icon(Icons.Default.CropSquare, contentDescription = "Tabs", tint = Gray600, modifier = Modifier.size(20.dp))
                                    Text(
                                        text = openTabs.size.toString(),
                                        fontSize = 8.sp,
                                        fontWeight = FontWeight.Bold,
                                        color = Gray600,
                                        modifier = Modifier.padding(top = 2.dp)
                                    )
                                }
                                // Menu Button
                                Box(
                                    modifier = Modifier
                                        .size(38.dp)
                                        .background(SurfaceWhite, CircleShape)
                                        .border(1.dp, Gray200, CircleShape)
                                        .clickable { showMenuSheet = true },
                                    contentAlignment = Alignment.Center
                                ) {
                                    Icon(Icons.Default.MoreVert, contentDescription = "Menu", tint = Gray600, modifier = Modifier.size(20.dp))
                                }
                            }
                        }
                    }

                    // Edge Loading Bar
                    Box(modifier = Modifier
                        .fillMaxWidth()
                        .height(2.dp)
                        .background(Gray100)) {
                        val animatedProgress by animateFloatAsState(targetValue = loadingProgress, animationSpec = tween(durationMillis = 300))
                        Box(
                            modifier = Modifier
                                .fillMaxWidth(animatedProgress)
                                .fillMaxHeight()
                                .background(PrimaryBlue)
                        )
                    }
                }
            }

            // --- FAVORITES GRID ---
            Column(modifier = Modifier
                .fillMaxSize()
                .padding(horizontal = 24.dp, vertical = 24.dp)) {
                
                Text(
                    text = "FAVORITES",
                    fontSize = 10.sp,
                    fontWeight = FontWeight.Bold,
                    color = Gray400,
                    letterSpacing = 2.sp,
                    modifier = Modifier.padding(bottom = 24.dp)
                )

                LazyVerticalGrid(
                    columns = GridCells.Fixed(4),
                    horizontalArrangement = Arrangement.spacedBy(16.dp),
                    verticalArrangement = Arrangement.spacedBy(32.dp)
                ) {
                    itemsIndexed(favorites) { _, site ->
                        Column(
                            horizontalAlignment = Alignment.CenterHorizontally,
                            modifier = Modifier.clickable(
                                interactionSource = remember { MutableInteractionSource() },
                                indication = null
                            ) {
                                searchQuery = "${site.name.lowercase()}.com"
                                simulateLoading()
                            }
                        ) {
                            Box(
                                modifier = Modifier
                                    .size(56.dp)
                                    .background(SurfaceWhite, CircleShape)
                                    .border(1.dp, Gray100, CircleShape),
                                contentAlignment = Alignment.Center
                            ) {
                                Text(
                                    text = site.initial,
                                    fontSize = 24.sp,
                                    fontWeight = FontWeight.Bold,
                                    color = site.color
                                )
                            }
                            Spacer(modifier = Modifier.height(8.dp))
                            Text(
                                text = site.name.uppercase(),
                                fontSize = 9.sp,
                                fontWeight = FontWeight.Bold,
                                color = Gray400,
                                maxLines = 1,
                                overflow = TextOverflow.Ellipsis
                            )
                        }
                    }
                    
                    // ADD BUTTON
                    item {
                        Column(
                            horizontalAlignment = Alignment.CenterHorizontally,
                            modifier = Modifier.clickable(
                                interactionSource = remember { MutableInteractionSource() },
                                indication = null
                            ) { /* Add action */ }
                        ) {
                            Box(
                                modifier = Modifier
                                    .size(56.dp)
                                    .background(Gray50, CircleShape)
                                    .border(1.dp, Gray200, CircleShape),
                                contentAlignment = Alignment.Center
                            ) {
                                Icon(Icons.Default.Add, contentDescription = "Add", tint = Gray300)
                            }
                            Spacer(modifier = Modifier.height(8.dp))
                            Text(
                                text = "ADD",
                                fontSize = 9.sp,
                                fontWeight = FontWeight.Bold,
                                color = Gray300,
                                letterSpacing = 0.5.sp
                            )
                        }
                    }
                }
            }
        }

        // Overlay when search is focused
        AnimatedVisibility(visible = isSearchFocused) {
            Box(
                modifier = Modifier
                    .fillMaxSize()
                    .background(Color.Black.copy(alpha = 0.05f))
                    .clickable(
                        interactionSource = remember { MutableInteractionSource() },
                        indication = null
                    ) { clearFocusAndOverlays() }
            )
        }
    }

    // --- TABS BOTTOM SHEET ---
    if (showTabsSheet) {
        ModalBottomSheet(
            onDismissRequest = { showTabsSheet = false },
            containerColor = SurfaceWhite,
            dragHandle = null,
            shape = RoundedCornerShape(topStart = 20.dp, topEnd = 20.dp)
        ) {
            Column(modifier = Modifier.padding(bottom = 32.dp)) {
                Box(modifier = Modifier
                    .padding(top = 12.dp, bottom = 12.dp)
                    .size(width = 32.dp, height = 4.dp)
                    .background(Gray200, CircleShape)
                    .align(Alignment.CenterHorizontally))

                Row(
                    modifier = Modifier
                        .fillMaxWidth()
                        .padding(horizontal = 24.dp, vertical = 16.dp),
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text("MANAGE TABS", fontSize = 10.sp, fontWeight = FontWeight.Bold, color = Gray400, letterSpacing = 2.sp)
                    Text("NEW TAB", fontSize = 10.sp, fontWeight = FontWeight.Bold, color = PrimaryBlue, modifier = Modifier.clickable {
                        openTabs.add(BrowserTab("new-tab", "N", Gray600))
                    })
                }

                LazyRow(
                    contentPadding = PaddingValues(horizontal = 24.dp),
                    horizontalArrangement = Arrangement.spacedBy(16.dp)
                ) {
                    itemsIndexed(openTabs) { index, tab ->
                        Box(modifier = Modifier.width(52.dp).height(56.dp)) {
                            Box(
                                modifier = Modifier
                                    .size(52.dp)
                                    .align(Alignment.BottomStart)
                                    .background(SurfaceWhite, CircleShape)
                                    .border(if (index == 0) 2.5.dp else 1.dp, if (index == 0) PrimaryBlue else Gray200, CircleShape)
                                    .clickable {
                                        searchQuery = tab.url
                                        clearFocusAndOverlays()
                                        simulateLoading()
                                    },
                                contentAlignment = Alignment.Center
                            ) {
                                Text(tab.initial, fontSize = 20.sp, fontWeight = FontWeight.Bold, color = tab.color)
                            }
                            
                            // Close Badge
                            Box(
                                modifier = Modifier
                                    .size(20.dp)
                                    .align(Alignment.TopEnd)
                                    .background(Gray800, CircleShape)
                                    .border(1.5.dp, SurfaceWhite, CircleShape)
                                    .clickable {
                                        if (openTabs.size > 1) openTabs.removeAt(index)
                                    },
                                contentAlignment = Alignment.Center
                            ) {
                                Icon(Icons.Default.Close, contentDescription = "Close", tint = SurfaceWhite, modifier = Modifier.size(12.dp))
                            }
                        }
                    }
                }
            }
        }
    }

    // --- MENU BOTTOM SHEET ---
    if (showMenuSheet) {
        ModalBottomSheet(
            onDismissRequest = { showMenuSheet = false },
            containerColor = SurfaceWhite,
            dragHandle = null,
            shape = RoundedCornerShape(topStart = 20.dp, topEnd = 20.dp)
        ) {
            Column(modifier = Modifier.padding(bottom = 32.dp)) {
                Box(modifier = Modifier
                    .padding(top = 12.dp, bottom = 12.dp)
                    .size(width = 32.dp, height = 4.dp)
                    .background(Gray200, CircleShape)
                    .align(Alignment.CenterHorizontally))

                // Zoom Row
                Row(modifier = Modifier
                    .fillMaxWidth()
                    .padding(horizontal = 24.dp, vertical = 12.dp),
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Row(verticalAlignment = Alignment.CenterVertically) {
                        Icon(Icons.Default.Search, contentDescription = "Zoom", tint = Gray500, modifier = Modifier.size(20.dp))
                        Spacer(modifier = Modifier.width(12.dp))
                        Text("ZOOM LEVEL", fontSize = 10.sp, fontWeight = FontWeight.Bold, color = Gray600)
                    }
                    Row(
                        modifier = Modifier
                            .border(1.dp, Gray200, CircleShape)
                            .padding(horizontal = 8.dp, vertical = 4.dp),
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Text("-", fontSize = 14.sp, fontWeight = FontWeight.Bold, color = Gray400, modifier = Modifier
                            .clickable { if (zoomLevel > 50) zoomLevel -= 10 }
                            .padding(horizontal = 8.dp))
                        Text("$zoomLevel%", fontSize = 10.sp, fontWeight = FontWeight.Bold, color = Gray600, modifier = Modifier.width(40.dp), textAlign = TextAlign.Center)
                        Text("+", fontSize = 14.sp, fontWeight = FontWeight.Bold, color = Gray400, modifier = Modifier
                            .clickable { if (zoomLevel < 200) zoomLevel += 10 }
                            .padding(horizontal = 8.dp))
                    }
                }

                Divider(color = Gray50, thickness = 1.dp)

                MenuRowItem(icon = Icons.Default.Refresh, title = "REFRESH PAGE") {
                    simulateLoading()
                    clearFocusAndOverlays()
                }
                
                MenuToggleItem(icon = Icons.Default.DesktopMac, title = "DESKTOP SITE", isChecked = isDesktopMode) {
                    isDesktopMode = !isDesktopMode
                }
                
                MenuToggleItem(icon = Icons.Default.DarkMode, title = "DARK MODE", isChecked = isDarkMode) {
                    isDarkMode = !isDarkMode
                }

                MenuRowItem(icon = Icons.Default.History, title = "HISTORY") {}

                Spacer(modifier = Modifier.height(16.dp))

                Box(modifier = Modifier
                    .fillMaxWidth()
                    .padding(horizontal = 24.dp)
                    .height(44.dp)
                    .background(Gray800, CircleShape)
                    .clickable { showMenuSheet = false },
                    contentAlignment = Alignment.Center
                ) {
                    Text("CLOSE", fontSize = 9.sp, fontWeight = FontWeight.Bold, color = SurfaceWhite, letterSpacing = 2.sp)
                }
            }
        }
    }
}

@Composable
fun MenuRowItem(icon: androidx.compose.ui.graphics.vector.ImageVector, title: String, onClick: () -> Unit) {
    Row(modifier = Modifier
        .fillMaxWidth()
        .clickable { onClick() }
        .padding(horizontal = 24.dp, vertical = 16.dp),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Icon(icon, contentDescription = title, tint = Gray500, modifier = Modifier.size(20.dp))
        Spacer(modifier = Modifier.width(12.dp))
        Text(title, fontSize = 10.sp, fontWeight = FontWeight.Bold, color = Gray600)
    }
}

@Composable
fun MenuToggleItem(icon: androidx.compose.ui.graphics.vector.ImageVector, title: String, isChecked: Boolean, onToggle: () -> Unit) {
    Row(modifier = Modifier
        .fillMaxWidth()
        .clickable { onToggle() }
        .padding(horizontal = 24.dp, vertical = 16.dp),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Row(verticalAlignment = Alignment.CenterVertically) {
            Icon(icon, contentDescription = title, tint = Gray500, modifier = Modifier.size(20.dp))
            Spacer(modifier = Modifier.width(12.dp))
            Text(title, fontSize = 10.sp, fontWeight = FontWeight.Bold, color = Gray600)
        }
        
        // Custom iOS-Style Toggle
        val trackColor by animateColorAsState(if (isChecked) PrimaryBlue else Gray200)
        val thumbOffset by animateDpAsState(if (isChecked) 16.dp else 2.dp)
        
        Box(modifier = Modifier
            .width(32.dp)
            .height(16.dp)
            .background(trackColor, CircleShape)) {
            Box(modifier = Modifier
                .padding(top = 2.dp)
                .size(12.dp)
                .offset(x = thumbOffset)
                .background(SurfaceWhite, CircleShape))
        }
    }
}
