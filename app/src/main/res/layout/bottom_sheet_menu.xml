<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F2F2F7"
    android:padding="20dp">

    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#E5E7EB" />

    <!-- Zoom & Refresh Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <!-- Refresh -->
        <LinearLayout
            android:id="@+id/refreshBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_refresh" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refresh"
                android:textColor="#1F2937"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#E5E7EB" />

        <!-- Zoom Controls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/zoomOutBtn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_zoom_button"
                android:src="@drawable/ic_minus"
                android:scaleType="center" />

            <TextView
                android:id="@+id/zoomLevelText"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="#1F2937"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/zoomInBtn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_zoom_button"
                android:src="@drawable/ic_plus"
                android:scaleType="center" />

        </LinearLayout>

    </LinearLayout>

    <!-- Privacy Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:layout_marginTop="12dp">

        <!-- Cookie Management -->
        <LinearLayout
            android:id="@+id/cookieManageBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_icon_blue"
                android:gravity="center">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_cookie" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cookie Management"
                    android:textColor="#1F2937"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Block third-party, exceptions"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp" />

            </LinearLayout>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_right" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6" />

        <!-- Tracking Protection -->
        <LinearLayout
            android:id="@+id/trackingProtectionRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_icon_orange"
                android:gravity="center">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_shield" />

            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tracking Protection"
                android:textColor="#1F2937"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/trackingToggle"
                android:layout_width="42dp"
                android:layout_height="26dp"
                android:checked="true"
                android:thumb="@drawable/bg_toggle_thumb"
                android:track="@drawable/bg_toggle_track" />

        </LinearLayout>

    </LinearLayout>

    <!-- Desktop Mode -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:id="@+id/desktopModeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_icon_gray"
                android:gravity="center">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_desktop" />

            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Desktop Site"
                android:textColor="#1F2937"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/desktopToggle"
                android:layout_width="42dp"
                android:layout_height="26dp"
                android:checked="false"
                android:thumb="@drawable/bg_toggle_thumb"
                android:track="@drawable/bg_toggle_track" />

        </LinearLayout>

    </LinearLayout>

    <!-- Close Menu Button -->
    <TextView
        android:id="@+id/closeMenuBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_white"
        android:gravity="center"
        android:text="CLOSE MENU"
        android:textColor="#6B7280"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

</LinearLayout>
